# =========================
# Raw data providers
# =========================
MORALIS_API_KEY=replace_with_moralis_api_key
CRYPTOAPIS_API_KEY=replace_with_cryptoapis_api_key
CRYPTOAPIS_BLOCKCHAIN=ethereum
CRYPTOAPIS_NETWORK=mainnet
CRYPTOPANIC_API_KEY=replace_with_cryptopanic_api_key
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com/fapi/v1
BINANCE_API_KEY=replace_with_optional_binance_api_key
BINANCE_API_SECRET=replace_with_optional_binance_api_secret

# =========================
# Workspace integrations
# =========================
NOTION_TOKEN=replace_with_notion_token
SLACK_TOKEN=replace_with_slack_token
SCALP_BOARD_DB_ID=replace_with_scalp_board_database_id
SCALP_UPDATES_DB_ID=replace_with_scalp_updates_database_id
ASSET_LIBRARY_DB_ID=replace_with_asset_library_database_id
WHALE_REGISTRY_DB_ID=replace_with_whale_registry_database_id
WALLET_ACTIVITY_DB_ID=replace_with_wallet_activity_database_id
VALIDATION_QUEUE_DB_ID=replace_with_validation_queue_database_id
CORRELATION_BOARD_DB_ID=replace_with_correlation_board_database_id
DECISION_QUEUE_DB_ID=replace_with_decision_queue_database_id
ALERTS_CHANNEL_ID=replace_with_alerts_channel_id
SIGNALS_CHANNEL_ID=replace_with_signals_channel_id
SCALP_UPDATES_CHANNEL_ID=replace_with_scalp_updates_channel_id
WATCHLIST_UPDATES_CHANNEL_ID=replace_with_watchlist_updates_channel_id
WALLET_ALERTS_CHANNEL_ID=replace_with_wallet_alerts_channel_id
OPS_CHANNEL_ID=replace_with_ops_channel_id

# =========================
# Black Box / persistence
# =========================
BLACKBOX_MODE=local_first
LOCAL_BLACKBOX_PATH=local_blackbox.sqlite
DATABASE_URL=replace_with_optional_railway_postgres_url
RAILWAY_MIRROR_ENABLED=false
RAILWAY_MIRROR_BATCH_SIZE=250

# =========================
# Runtime controls
# =========================
SELECTED_ASSETS_SOURCE=queue
SELECTED_ASSETS_FILE=runs/selected_assets.json
VALIDATION_BATCH_SIZE=25
ENABLE_OPENVINO_ANALYSTS=false
ANALYST_CACHE_TTL_SECONDS=900
